# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============ Blockchain ============
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_DEFAULT_CHAIN=polygon

# ============ IPFS / Pinata ============
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
PINATA_JWT=

# ============ Backend API ============
NEXT_PUBLIC_API_URL=http://localhost:3001
API_SECRET_KEY=

# ============ Database (Backend) ============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/artgenesis
REDIS_URL=redis://localhost:6379

# ============ JWT (Backend) ============
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=7d

# ============ Contract Addresses ============
NEXT_PUBLIC_NFT_CONTRACT_POLYGON=
NEXT_PUBLIC_MARKETPLACE_CONTRACT_POLYGON=
NEXT_PUBLIC_AUCTION_CONTRACT_POLYGON=
NEXT_PUBLIC_TREASURY_CONTRACT_POLYGON=

# ============ Analytics ============
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ============ Deployer (Contracts) ============
DEPLOYER_PRIVATE_KEY=
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
