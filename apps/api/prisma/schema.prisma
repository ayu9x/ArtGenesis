// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  address          String?   @unique
  nonce            String?   // For SIWE authentication
  email            String?   @unique
  passwordHash     String?
  googleId         String?   @unique
  resetToken       String?
  resetTokenExpiry DateTime?
  username         String?   @unique
  bio              String?
  avatarUrl        String?
  coverUrl         String?
  twitter          String?
  instagram        String?
  website          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  nfts      NFT[]
  collections Collection[]
  activities Activity[]
}

model Collection {
  id              String   @id @default(uuid())
  contractAddress String   @unique
  chainId         Int
  name            String
  symbol          String
  description     String?
  imageUrl        String?
  coverUrl        String?
  creatorAddress  String
  creator         User     @relation(fields: [creatorAddress], references: [address])
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  nfts            NFT[]
}

model NFT {
  id              String   @id @default(uuid())
  tokenId         String
  contractAddress String
  ownerAddress    String
  owner           User     @relation(fields: [ownerAddress], references: [address])
  collection      Collection @relation(fields: [contractAddress], references: [contractAddress])
  
  name            String
  description     String?
  imageUrl        String
  metadataUrl     String
  attributes      String?    // Stored as JSON string (SQLite doesn't support Json type)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        Listing[]
  activities      Activity[]

  @@unique([contractAddress, tokenId])
}

// SQLite does not support enums, using strings instead
// ListingType: "FIXED_PRICE" | "AUCTION"
// ListingStatus: "ACTIVE" | "SOLD" | "CANCELLED" | "EXPIRED"

model Listing {
  id              String        @id @default(uuid())
  listingId       String        // ID from smart contract
  type            String
  status          String        @default("ACTIVE")
  price           String        // Stored as string to handle uint256
  startTime       DateTime?
  endTime         DateTime?
  
  nftId           String
  nft             NFT           @relation(fields: [nftId], references: [id])
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ActivityType: "MINT" | "LIST" | "SALE" | "TRANSFER" | "BID" | "CANCEL"

model Activity {
  id              String       @id @default(uuid())
  type            String
  txHash          String?
  price           String?      // If applicable (sale, list, bid)
  
  fromAddress     String?
  toAddress       String?
  
  nftId           String
  nft             NFT          @relation(fields: [nftId], references: [id])
  
  userId          String?      // User who initiated or is associated
  user            User?        @relation(fields: [userId], references: [id])

  createdAt       DateTime     @default(now())
}
